# Minutos entre regeneraciones automáticas del snapshot
REFRESH_INTERVAL_MINUTES=60

# Token opcional para proteger POST /refresh (déjalo vacío para no exigir auth)
REFRESH_TOKEN=

# Coordenadas para Open-Meteo (default Valencia centro)
WEATHER_LAT=39.4697
WEATHER_LON=-0.3774
WEATHER_TZ=Europe/Madrid

# URL pública del artifact del CSV de previsiones generado por el equipo de modelado.
# Si está definida, el backend la descarga automáticamente cada vez que regenera el
# snapshot (cada REFRESH_INTERVAL_MINUTES). Déjala vacía para usar solo el archivo
# local en backend/data/predicciones_contaminantes.csv.
FORECAST_CSV_URL=https://gitlab.com/api/v4/projects/82377482/jobs/artifacts/main/raw/public_output/predicciones_contaminantes.csv?job=publish_job
